#!/usr/bin/env bash

BASE="$(cd "$(dirname "$0")/.." && pwd)"
ARTIFACTS="$BASE/artifacts"

CMD="$1"
ID="$2"
TITLE="$3"

META="$ARTIFACTS/$ID/meta.json"

mkdir -p "$ARTIFACTS/$ID"

case "$CMD" in

  new)
    if [ -z "$TITLE" ]; then
      echo "ERROR: title required"
      exit 1
    fi

    # HARD GUARANTEE: never create empty file
    cat > "$META" <<EOF2
{
  "id": "$ID",
  "title": "$TITLE",
  "state": "draft",
  "version": 1
}
EOF2

    # validation check
    if [ ! -s "$META" ]; then
      echo "ERROR: failed to create meta.json"
      exit 1
    fi

    echo "Created: $ID"
  ;;

  publish)
    if [ ! -s "$META" ]; then
      echo "Empty meta.json"
      echo "ERROR: publish failed for $ID"
      exit 1
    fi

    python - "$META" << 'PY'
import json, sys
from pathlib import Path

p = Path(sys.argv[1]).resolve()
data = json.loads(p.read_text(encoding="utf-8"))
data["state"] = "published"
p.write_text(json.dumps(data), encoding="utf-8")
print("OK")
PY

    echo "Published: $ID"
  ;;

  status)
    cat "$META" 2>/dev/null || echo "Not found"
  ;;

  *)
    echo "Commands: new | publish | status"
  ;;
esac
