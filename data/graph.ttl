@prefix : <https://padi.io/ontology/> .

# --- Harmonized Connections ---
# We link McKinsey to the L1 Practice Area defined in the Taxonomy
:McKinsey_Forward a :EpistemicAsset ;
    :belongsTo :L1_MCP ;
    :status "In-Progress" .

# We link the Framework to the McKinsey program
:ProblemSolvingFramework :belongsTo :McKinsey_Forward .
