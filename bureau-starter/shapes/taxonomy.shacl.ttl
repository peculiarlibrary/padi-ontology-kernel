@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix core: <https://padi-standard.org/ns/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

core:ConceptShape
    a sh:NodeShape ;
    sh:targetClass core:Concept ;
    sh:property [
        sh:path core:label ;
        sh:datatype xsd:string ;
        sh:minCount 1 ;
    ] .
