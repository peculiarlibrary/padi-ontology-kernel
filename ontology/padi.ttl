@prefix : <https://padi.io/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

# --- Classes ---
:PracticeArea a owl:Class .
:EpistemicAsset a owl:Class .
:Publication a owl:Class .

# --- Properties (The Missing Links) ---
:hasLevel a owl:DatatypeProperty ;
    rdfs:domain :PracticeArea .

:belongsTo a owl:ObjectProperty ;
    rdfs:domain :EpistemicAsset ;
    rdfs:range :PracticeArea .

:authoredBy a owl:ObjectProperty ;
    rdfs:domain :Publication ;
    rdfs:range :EpistemicAsset .
