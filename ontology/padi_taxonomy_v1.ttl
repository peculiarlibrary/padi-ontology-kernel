@prefix padi: <https://peculiarlibrary.github.io/padi-ontology-kernel#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

### --- PADI MASTER TAXONOMY V1.2 --- ###

padi:PracticeArea a owl:Class ;
    rdfs:label "Practice Area" ;
    rdfs:comment "A top-level domain defining the scope of the Sovereign Bureau." .

# --- L1: PRIMARY DOMAINS --- #

padi:InformationScience a padi:PracticeArea ;
    rdfs:label "Information Science" .

padi:DigitalCommunications a padi:PracticeArea ;
    rdfs:label "Digital Communications" .

padi:SystemsArchitecture a padi:PracticeArea ;
    rdfs:label "Systems Architecture" ;
    rdfs:comment "The design and governance of complex information systems." .

padi:ResearchAnalysis a padi:PracticeArea ;
    rdfs:label "Research Analysis" ;
    rdfs:comment "Systematic investigation and evaluation of information sources." .

# --- L2: DEPTH NODES & SPECIALIZATIONS --- #

padi:Librarianship a padi:InformationScience ;
    rdfs:label "Librarianship" ;
    padi:hasDepth "L2"^^xsd:string .

padi:OntologyEngineering a padi:InformationScience ;
    rdfs:label "Ontology Engineering" ;
    padi:hasDepth "L2"^^xsd:string .

padi:AgenticOrchestration a padi:SystemsArchitecture ;
    rdfs:label "Agentic Orchestration" ;
    padi:hasDepth "L2"^^xsd:string .

padi:StructuredAnalysis a padi:ResearchAnalysis ;
    rdfs:label "Structured Analysis" ;
    padi:hasDepth "L2"^^xsd:string .
