@prefix : <https://padi.io/ontology/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .

:PracticeArea a owl:Class ;
    rdfs:label "Practice Area" .

:L1_MCP a :PracticeArea ;
    :hasLevel "L1" ;
    rdfs:label "Model Context Protocol" .

:L2_SemanticWeb a :PracticeArea ;
    :hasLevel "L2" ;
    rdfs:label "Semantic Web & Knowledge Graphs" .

:L3_AgenticSystems a :PracticeArea ;
    :hasLevel "L3" ;
    rdfs:label "Agentic Information Science" .
